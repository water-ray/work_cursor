{
  "name": "wateray-electron-app",
  "version": "0.4.7",
  "private": true,
  "description": "Wateray desktop frontend powered by Electron + React + Ant Design",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package:win-unpacked": "electron-packager . WaterayApp --platform=win32 --arch=x64 --icon=ico.ico --out=out-package --overwrite --asar --prune=true",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "antd": "^6.3.1",
    "bootstrap-icons": "^1.13.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.6.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
