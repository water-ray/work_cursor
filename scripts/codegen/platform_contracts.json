{
  "runtimeAppTargets": [
    "desktop",
    "mobile"
  ],
  "runtimePlatforms": {
    "desktop": {
      "kind": "desktop",
      "isMobile": false,
      "supportsWindowControls": true,
      "supportsTray": true,
      "supportsPackagedDaemon": true,
      "supportsSystemProxyMode": true,
      "supportsLocalFileAccess": true,
      "supportsInAppUpdates": true,
      "supportsMobileVpnHost": false,
      "requiresSandboxDataRoot": false
    },
    "android": {
      "kind": "android",
      "isMobile": true,
      "supportsWindowControls": false,
      "supportsTray": false,
      "supportsPackagedDaemon": false,
      "supportsSystemProxyMode": false,
      "supportsLocalFileAccess": false,
      "supportsInAppUpdates": false,
      "supportsMobileVpnHost": true,
      "requiresSandboxDataRoot": true
    },
    "ios": {
      "kind": "ios",
      "isMobile": true,
      "supportsWindowControls": false,
      "supportsTray": false,
      "supportsPackagedDaemon": false,
      "supportsSystemProxyMode": false,
      "supportsLocalFileAccess": false,
      "supportsInAppUpdates": false,
      "supportsMobileVpnHost": false,
      "requiresSandboxDataRoot": true
    }
  },
  "mobileHost": {
    "pluginName": "mobile-host",
    "androidPluginIdentifier": "com.singbox.wateray.mobilehost",
    "androidPluginClass": "MobileHostPlugin",
    "commands": [
      {
        "key": "bootstrap",
        "invokeCommand": "mobile_host_bootstrap",
        "pluginCommand": "bootstrap",
        "permission": "mobile-host:allow-bootstrap"
      },
      {
        "key": "getStatus",
        "invokeCommand": "mobile_host_get_status",
        "pluginCommand": "getStatus",
        "permission": "mobile-host:allow-getStatus"
      },
      {
        "key": "getVersions",
        "invokeCommand": "mobile_host_get_versions",
        "pluginCommand": "getVersions",
        "permission": "mobile-host:allow-getVersions"
      },
      {
        "key": "listInstalledApps",
        "invokeCommand": "mobile_host_list_installed_apps",
        "pluginCommand": "listInstalledApps",
        "permission": "mobile-host:allow-listInstalledApps"
      },
      {
        "key": "getInstalledAppIcon",
        "invokeCommand": "mobile_host_get_installed_app_icon",
        "pluginCommand": "getInstalledAppIcon",
        "permission": "mobile-host:allow-getInstalledAppIcon"
      },
      {
        "key": "prepare",
        "invokeCommand": "mobile_host_prepare",
        "pluginCommand": "prepare",
        "permission": "mobile-host:allow-prepare"
      },
      {
        "key": "checkConfig",
        "invokeCommand": "mobile_host_check_config",
        "pluginCommand": "checkConfig",
        "permission": "mobile-host:allow-checkConfig"
      },
      {
        "key": "start",
        "invokeCommand": "mobile_host_start",
        "pluginCommand": "start",
        "permission": "mobile-host:allow-start"
      },
      {
        "key": "stop",
        "invokeCommand": "mobile_host_stop",
        "pluginCommand": "stop",
        "permission": "mobile-host:allow-stop"
      },
      {
        "key": "clearDnsCache",
        "invokeCommand": "mobile_host_clear_dns_cache",
        "pluginCommand": "clearDnsCache",
        "permission": "mobile-host:allow-clearDnsCache"
      },
      {
        "key": "probe",
        "invokeCommand": "mobile_host_probe",
        "pluginCommand": "probe",
        "permission": "mobile-host:allow-probe"
      },
      {
        "key": "probeStart",
        "invokeCommand": "mobile_host_probe_start",
        "pluginCommand": "probeStart",
        "permission": "mobile-host:allow-probeStart"
      },
      {
        "key": "probeCancel",
        "invokeCommand": "mobile_host_probe_cancel",
        "pluginCommand": "probeCancel",
        "permission": "mobile-host:allow-probeCancel"
      },
      {
        "key": "getTaskQueue",
        "invokeCommand": "mobile_host_get_task_queue",
        "pluginCommand": "getTaskQueue",
        "permission": "mobile-host:allow-getTaskQueue"
      },
      {
        "key": "dnsHealth",
        "invokeCommand": "mobile_host_dns_health",
        "pluginCommand": "dnsHealth",
        "permission": "mobile-host:allow-dnsHealth"
      },
      {
        "key": "switchSelectors",
        "invokeCommand": "mobile_host_switch_selectors",
        "pluginCommand": "switchSelectors",
        "permission": "mobile-host:allow-switchSelectors"
      }
    ]
  }
}
