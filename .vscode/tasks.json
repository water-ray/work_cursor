      "type": "shell",
      "command": "go run -tags with_clash_api,with_gvisor ./cmd/waterayd",
      "options": {
        "cwd": "${workspaceFolder}/core"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "wateray: build windows client",
      "type": "shell",
      "command": "python scripts/build/build_windows_client.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "wateray: release dry-run (patch)",
      "type": "shell",
      "command": "python scripts/release/release_version.py patch --dry-run",
