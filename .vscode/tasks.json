{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "githubPrivateRepoUrl",
      "type": "promptString",
      "description": "输入私有源码仓库 Git URL",
      "default": "https://github.com/water-ray/wateray-src.git"
    },
    {
      "id": "githubPrivateRemoteName",
      "type": "promptString",
      "description": "输入私有源码仓库 remote 名称",
      "default": "source-private"
    },
    {
      "id": "githubPrivateBranch",
      "type": "promptString",
      "description": "输入要推送到私有源码仓库的分支名",
      "default": "main"
    },
    {
      "id": "githubPublicRepo",
      "type": "promptString",
      "description": "输入公开发布仓库 owner/name",
      "default": "water-ray/wateray-release"
    },
    {
      "id": "gitCommitMessage",
      "type": "promptString",
      "description": "输入本次提交说明",
      "default": "chore: update project files"
    },
    {
      "id": "gitTargetBranch",
      "type": "promptString",
      "description": "输入目标分支名（例如 feat/my-change、fix/bug-123、release/v1.1.0）",
      "default": "feat/my-change"
    },
    {
      "id": "gitPublicRemoteName",
      "type": "promptString",
      "description": "输入公开仓库 remote 名称",
      "default": "origin"
    }
  ],
  "tasks": [
    {
      "label": "客户端：开发：运行 Electron 前端",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/ElectronApp",
        "env": {
          "ELECTRON_DISABLE_SANDBOX": "1",
          "WATERAY_APP_MODE": "dev",
          "VITE_AIRPORT_WEB_URL": "http://127.0.0.1:5179/"
        }
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "客户端：构建：Electron 前端",
      "type": "shell",
      "command": "npm run build",
      "linux": {
        "command": "node node_modules/electron-vite/bin/electron-vite.js build"
      },
      "options": {
        "cwd": "${workspaceFolder}/ElectronApp",
        "env": {
          "VITE_AIRPORT_WEB_URL": "https://wateray.net/"
        }
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：检查：Electron 类型检查",
      "type": "shell",
      "command": "npm run typecheck",
      "linux": {
        "command": "node node_modules/typescript/bin/tsc --noEmit"
      },
      "options": {
        "cwd": "${workspaceFolder}/ElectronApp"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "广告端：开发：运行服务端",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/adsroot/server"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "广告端：开发：运行前端",
      "type": "shell",
      "command": "npm run dev",
      "linux": {
        "command": "node node_modules/vite/bin/vite.js"
      },
      "options": {
        "cwd": "${workspaceFolder}/adsroot/web"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "广告端：本地发布：服务端到 Bin/adsroot",
      "type": "shell",
      "command": "$ErrorActionPreference = 'Stop'; $serverSrc = Join-Path '${workspaceFolder}' 'adsroot/server'; $publishServer = Join-Path '${workspaceFolder}' 'Bin/adsroot/server'; npm run build --prefix $serverSrc; if (Test-Path $publishServer) { Remove-Item -Path $publishServer -Recurse -Force }; New-Item -ItemType Directory -Path $publishServer -Force | Out-Null; Copy-Item -Path (Join-Path $serverSrc 'dist') -Destination $publishServer -Recurse -Force; Set-Content -Path (Join-Path $publishServer 'main.js') -Value 'import ''./dist/main.js'';' -Encoding UTF8; $serverFiles = @('package.json', 'package-lock.json', '.env.example', 'README.md', 'install.sh'); foreach ($name in $serverFiles) { $sourcePath = Join-Path $serverSrc $name; if (Test-Path $sourcePath) { Copy-Item -Path $sourcePath -Destination $publishServer -Force } }; Get-ChildItem -Path $publishServer -Recurse -File | Where-Object { $_.Extension -eq '.sqlite' -or $_.Name.EndsWith('.sqlite-wal') -or $_.Name.EndsWith('.sqlite-shm') } | Remove-Item -Force",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "广告端：本地发布：前端到 Bin/adsroot",
      "type": "shell",
      "command": "$ErrorActionPreference = 'Stop'; npm run build --prefix \"${workspaceFolder}/adsroot/web\"; $publishWeb = Join-Path '${workspaceFolder}' 'Bin/adsroot/web'; if (Test-Path $publishWeb) { Remove-Item -Path $publishWeb -Recurse -Force }; New-Item -ItemType Directory -Path $publishWeb -Force | Out-Null; Copy-Item -Path \"${workspaceFolder}/adsroot/web/dist\" -Destination $publishWeb -Recurse -Force",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "广告端：本地发布：前后端整套到 Bin/adsroot",
      "dependsOn": [
        "广告端：本地发布：服务端到 Bin/adsroot",
        "广告端：本地发布：前端到 Bin/adsroot"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "客户端：开发：运行 VPN 内核",
      "type": "shell",
      "command": "python scripts/dev/run_waterayd.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：构建：当前平台客户端",
      "type": "shell",
      "command": "python scripts/build/targets/desktop.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：构建：Linux deb 安装包",
      "type": "shell",
      "command": "python scripts/build/targets/linux_package.py --format deb",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：构建：Linux AppImage",
      "type": "shell",
      "command": "python scripts/build/targets/linux_package.py --format appimage",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：构建：Linux 安装包（deb + AppImage）",
      "type": "shell",
      "command": "python scripts/build/targets/linux_package.py --format all",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：版本：补丁版预演",
      "type": "shell",
      "command": "python scripts/release/release_version.py patch --dry-run",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：版本：发布补丁版",
      "type": "shell",
      "command": "python scripts/release/release_version.py patch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：版本：发布次版本",
      "type": "shell",
      "command": "python scripts/release/release_version.py minor",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：版本：发布主版本",
      "type": "shell",
      "command": "python scripts/release/release_version.py major",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：版本：补丁版并构建当前平台客户端",
      "dependsOn": [
        "客户端：版本：发布补丁版",
        "客户端：构建：当前平台客户端"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "客户端：开发：运行桌面整套",
      "dependsOn": [
        "客户端：开发：运行 VPN 内核",
        "客户端：开发：运行 Electron 前端"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "私有源码：提交当前改动",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py commit",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "WATERAY_GIT_COMMIT_MESSAGE": "${input:gitCommitMessage}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：推送当前分支",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py push-current --remote \"${input:githubPrivateRemoteName}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：切换或创建 Git 分支",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py switch-branch --branch \"${input:gitTargetBranch}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：推送当前内容到 main",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py push-main --remote \"${input:githubPrivateRemoteName}\" --branch \"${input:githubPrivateBranch}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：提交并推送当前分支",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py commit-push-current --remote \"${input:githubPrivateRemoteName}\"",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "WATERAY_GIT_COMMIT_MESSAGE": "${input:gitCommitMessage}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：提交并推送到 main",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py commit-push-main --remote \"${input:githubPrivateRemoteName}\" --branch \"${input:githubPrivateBranch}\"",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "WATERAY_GIT_COMMIT_MESSAGE": "${input:gitCommitMessage}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：检查当前提交身份",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py show-identity",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：发布：准备当前平台发布素材",
      "type": "shell",
      "command": "python scripts/release/prepare_github_release.py --repo \"${input:githubPublicRepo}\" --platform current --release-root-dir \"Bin/github-staging-release\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：发布：构建当前平台发布产物",
      "dependsOn": [
        "客户端：构建：当前平台客户端",
        "客户端：发布：准备当前平台发布素材"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "公开发布：上传当前平台产物",
      "type": "shell",
      "command": "python scripts/release/upload_current_platform_release.py --repo \"${input:githubPublicRepo}\" --release-root-dir \"Bin/github-staging-release\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "公开发布：上传当前平台产物到 GitHub",
      "dependsOn": [
        "客户端：发布：构建当前平台发布产物",
        "公开发布：上传当前平台产物"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "公开发布：触发 GitHub 汇总发布",
      "type": "shell",
      "command": "python scripts/release/dispatch_github_release_workflow.py --public-repo \"${input:githubPublicRepo}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "公开发布：手工直发最终 Release（兜底）",
      "type": "shell",
      "command": "python scripts/release/publish_github_release.py --repo \"${input:githubPublicRepo}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    }
  ]
}
