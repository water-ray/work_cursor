{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "githubPrivateRepoUrl",
      "type": "promptString",
      "description": "输入私有源码仓库 Git URL",
      "default": "https://github.com/water-ray/wateray-src.git"
    },
    {
      "id": "githubPrivateRemoteName",
      "type": "promptString",
      "description": "输入私有源码仓库 remote 名称",
      "default": "source-private"
    },
    {
      "id": "githubPrivateBranch",
      "type": "promptString",
      "description": "输入要推送到私有源码仓库的分支名",
      "default": "main"
    },
    {
      "id": "githubPublicRepo",
      "type": "promptString",
      "description": "输入公开发布仓库 owner/name",
      "default": "water-ray/wateray-release"
    },
    {
      "id": "gitCommitMessage",
      "type": "promptString",
      "description": "输入本次提交说明",
      "default": "chore: update project files"
    },
    {
      "id": "gitTargetBranch",
      "type": "promptString",
      "description": "输入目标分支名（例如 feat/my-change、fix/bug-123、release/v1.1.0）",
      "default": "feat/my-change"
    },
    {
      "id": "gitPublicRemoteName",
      "type": "promptString",
      "description": "输入公开仓库 remote 名称",
      "default": "origin"
    }
  ],
  "tasks": [
    {
      "label": "内部：客户端：开发：运行 Electron 前端",
      "type": "shell",
      "hide": true,
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/ElectronApp",
        "env": {
          "WATERAY_APP_MODE": "dev",
          "VITE_AIRPORT_WEB_URL": "http://127.0.0.1:5179/"
        }
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "内部：客户端：构建：Electron 前端",
      "type": "shell",
      "hide": true,
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/ElectronApp",
        "env": {
          "VITE_AIRPORT_WEB_URL": "https://wateray.net/"
        }
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：客户端：检查：Electron 类型检查",
      "type": "shell",
      "hide": true,
      "command": "npm run typecheck",
      "options": {
        "cwd": "${workspaceFolder}/ElectronApp"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：广告端：开发：运行服务端",
      "type": "shell",
      "hide": true,
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/adsroot/server"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：广告端：开发：运行前端",
      "type": "shell",
      "hide": true,
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/adsroot/web"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：广告端：本地发布：服务端到 Bin/adsroot",
      "type": "shell",
      "hide": true,
      "command": "$ErrorActionPreference = 'Stop'; $serverSrc = Join-Path '${workspaceFolder}' 'adsroot/server'; $publishServer = Join-Path '${workspaceFolder}' 'Bin/adsroot/server'; npm run build --prefix $serverSrc; if (Test-Path $publishServer) { Remove-Item -Path $publishServer -Recurse -Force }; New-Item -ItemType Directory -Path $publishServer -Force | Out-Null; Copy-Item -Path (Join-Path $serverSrc 'dist') -Destination $publishServer -Recurse -Force; Set-Content -Path (Join-Path $publishServer 'main.js') -Value 'import ''./dist/main.js'';' -Encoding UTF8; $serverFiles = @('package.json', 'package-lock.json', '.env.example', 'README.md', 'install.sh'); foreach ($name in $serverFiles) { $sourcePath = Join-Path $serverSrc $name; if (Test-Path $sourcePath) { Copy-Item -Path $sourcePath -Destination $publishServer -Force } }; Get-ChildItem -Path $publishServer -Recurse -File | Where-Object { $_.Extension -eq '.sqlite' -or $_.Name.EndsWith('.sqlite-wal') -or $_.Name.EndsWith('.sqlite-shm') } | Remove-Item -Force",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：广告端：本地发布：前端到 Bin/adsroot",
      "type": "shell",
      "hide": true,
      "command": "$ErrorActionPreference = 'Stop'; npm run build --prefix \"${workspaceFolder}/adsroot/web\"; $publishWeb = Join-Path '${workspaceFolder}' 'Bin/adsroot/web'; if (Test-Path $publishWeb) { Remove-Item -Path $publishWeb -Recurse -Force }; New-Item -ItemType Directory -Path $publishWeb -Force | Out-Null; Copy-Item -Path \"${workspaceFolder}/adsroot/web/dist\" -Destination $publishWeb -Recurse -Force",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "广告端：本地发布：前后端整套到 Bin/adsroot",
      "dependsOn": [
        "内部：广告端：本地发布：服务端到 Bin/adsroot",
        "内部：广告端：本地发布：前端到 Bin/adsroot"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "内部：客户端：开发：运行 VPN 内核",
      "type": "shell",
      "hide": true,
      "command": "go run -tags with_clash_api,with_gvisor,with_quic ./cmd/waterayd",
      "options": {
        "cwd": "${workspaceFolder}/core"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：构建：Windows 客户端整包",
      "type": "shell",
      "command": "python scripts/build/targets/desktop.py --platform windows",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：客户端：构建：Linux 客户端整包",
      "type": "shell",
      "hide": true,
      "command": "python scripts/build/targets/desktop.py --platform linux",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：客户端：构建：macOS 客户端整包",
      "type": "shell",
      "hide": true,
      "command": "python scripts/build/targets/desktop.py --platform macos",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：客户端：版本：补丁版预演",
      "type": "shell",
      "hide": true,
      "command": "python scripts/release/release_version.py patch --dry-run",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：客户端：版本：发布补丁版",
      "type": "shell",
      "hide": true,
      "command": "python scripts/release/release_version.py patch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：客户端：版本：发布次版本",
      "type": "shell",
      "hide": true,
      "command": "python scripts/release/release_version.py minor",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：客户端：版本：发布主版本",
      "type": "shell",
      "hide": true,
      "command": "python scripts/release/release_version.py major",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：客户端：版本：补丁版并构建 Windows 客户端",
      "hide": true,
      "dependsOn": [
        "内部：客户端：版本：发布补丁版",
        "客户端：构建：Windows 客户端整包"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "客户端：开发：运行桌面整套",
      "dependsOn": [
        "内部：客户端：开发：运行 VPN 内核",
        "内部：客户端：开发：运行 Electron 前端"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "私有源码：提交当前改动",
      "type": "shell",
      "command": "$ErrorActionPreference = 'Stop'; git add -A; git diff --cached --quiet; if ($LASTEXITCODE -eq 0) { Write-Host '没有可提交的改动'; exit 0 }; git commit -m \"$env:WATERAY_GIT_COMMIT_MESSAGE\"; git status --short --branch",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "WATERAY_GIT_COMMIT_MESSAGE": "${input:gitCommitMessage}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：推送当前分支",
      "type": "shell",
      "command": "$ErrorActionPreference = 'Stop'; git push source-private HEAD",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：切换或创建 Git 分支",
      "type": "shell",
      "command": "$ErrorActionPreference = 'Stop'; $branch = '${input:gitTargetBranch}'; git show-ref --verify --quiet \"refs/heads/$branch\"; if ($LASTEXITCODE -eq 0) { git switch $branch } else { git switch -c $branch }; git branch --show-current",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "内部：私有源码：推送当前内容到 main",
      "type": "shell",
      "hide": true,
      "command": "$ErrorActionPreference = 'Stop'; git push -u source-private \"HEAD:main\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：提交并推送当前分支",
      "dependsOn": [
        "私有源码：提交当前改动",
        "私有源码：推送当前分支"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "私有源码：提交并推送到 main",
      "dependsOn": [
        "私有源码：提交当前改动",
        "内部：私有源码：推送当前内容到 main"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "内部：私有源码：检查当前提交身份",
      "type": "shell",
      "hide": true,
      "command": "git config --local --get user.name; git config --local --get user.email; git var GIT_AUTHOR_IDENT; git var GIT_COMMITTER_IDENT",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：公开发布：构建客户端发布产物",
      "dependsOn": [
        "客户端：构建：Windows 客户端整包"
      ],
      "hide": true,
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "内部：公开发布：生成客户端 Release 素材",
      "type": "shell",
      "hide": true,
      "command": "python scripts/release/prepare_github_release.py --repo \"${input:githubPublicRepo}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "内部：公开发布：构建并生成客户端 Release 素材",
      "hide": true,
      "dependsOn": [
        "内部：公开发布：构建客户端发布产物",
        "内部：公开发布：生成客户端 Release 素材"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "内部：公开发布：自动发布客户端 Release",
      "type": "shell",
      "hide": true,
      "command": "python scripts/release/publish_github_release.py --repo \"${input:githubPublicRepo}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "公开发布：构建并自动发布客户端 Release",
      "dependsOn": [
        "内部：公开发布：构建并生成客户端 Release 素材",
        "内部：公开发布：自动发布客户端 Release"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
