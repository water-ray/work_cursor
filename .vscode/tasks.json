{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "githubPrivateRemoteName",
      "type": "promptString",
      "description": "输入私有源码仓库 remote 名称",
      "default": "source-private"
    },
    {
      "id": "githubPrivateBranch",
      "type": "promptString",
      "description": "输入要推送到私有源码仓库的分支名",
      "default": "main"
    },
    {
      "id": "githubPublicRepo",
      "type": "promptString",
      "description": "输入公开发布仓库 owner/name",
      "default": "water-ray/wateray-release"
    },
    {
      "id": "gitCommitMessage",
      "type": "promptString",
      "description": "输入本次提交说明",
      "default": "chore: update project files"
    },
    {
      "id": "gitTargetBranch",
      "type": "promptString",
      "description": "输入目标分支名（例如 feat/my-change、fix/bug-123、release/v1.1.0）",
      "default": "feat/my-change"
    }
  ],
  "tasks": [
    {
      "label": "客户端：开发：运行 Tauri 前端",
      "type": "process",
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "windows": {
        "command": "python",
        "args": [
          "${workspaceFolder}\\scripts\\dev\\run_tauri_dev_watchdog.py"
        ],
        "options": {
          "cwd": "${workspaceFolder}",
          "env": {
            "WATERAY_APP_MODE": "dev",
            "VITE_AIRPORT_WEB_URL": "http://127.0.0.1:5179/"
          }
        }
      },
      "options": {
        "cwd": "${workspaceFolder}/TauriApp",
        "env": {
          "WATERAY_APP_MODE": "dev",
          "VITE_AIRPORT_WEB_URL": "http://127.0.0.1:5179/"
        }
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "客户端：检查：Tauri 类型检查",
      "type": "shell",
      "command": "npm run typecheck",
      "linux": {
        "command": "node node_modules/typescript/bin/tsc --noEmit"
      },
      "options": {
        "cwd": "${workspaceFolder}/TauriApp"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "广告端：开发：运行服务端",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/adsroot/server"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "广告端：开发：运行前端",
      "type": "shell",
      "command": "npm run dev",
      "linux": {
        "command": "node node_modules/vite/bin/vite.js"
      },
      "options": {
        "cwd": "${workspaceFolder}/adsroot/web"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "广告端：本地发布：前后端整套到 Bin/adsroot",
      "type": "shell",
      "command": "python scripts/build/targets/publish_adsroot.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：开发：运行 VPN 内核",
      "type": "shell",
      "command": "python scripts/dev/run_waterayd.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：构建：当前平台客户端",
      "type": "shell",
      "command": "python scripts/build/targets/build_current_platform_client.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：构建：清理 Tauri 编译缓存",
      "type": "process",
      "command": "cargo",
      "args": [
        "clean",
        "--manifest-path",
        "${workspaceFolder}/TauriApp/src-tauri/Cargo.toml"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：版本：发布补丁版",
      "type": "shell",
      "command": "python scripts/release/release_version.py patch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：版本：发布次版本",
      "type": "shell",
      "command": "python scripts/release/release_version.py minor",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "客户端：版本：发布主版本",
      "type": "shell",
      "command": "python scripts/release/release_version.py major",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "私有源码：提交当前改动",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py commit",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "WATERAY_GIT_COMMIT_MESSAGE": "${input:gitCommitMessage}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：推送当前分支",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py push-current --remote \"${input:githubPrivateRemoteName}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：切换或创建 Git 分支",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py switch-branch --branch \"${input:gitTargetBranch}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：查看当前分支",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py show-branch",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "私有源码：推送当前内容到 main",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py push-main --remote \"${input:githubPrivateRemoteName}\" --branch \"${input:githubPrivateBranch}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：提交并推送当前分支",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py commit-push-current --remote \"${input:githubPrivateRemoteName}\"",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "WATERAY_GIT_COMMIT_MESSAGE": "${input:gitCommitMessage}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：提交并推送到 main",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py commit-push-main --remote \"${input:githubPrivateRemoteName}\" --branch \"${input:githubPrivateBranch}\"",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "WATERAY_GIT_COMMIT_MESSAGE": "${input:gitCommitMessage}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "私有源码：检查当前提交身份",
      "type": "shell",
      "command": "python scripts/git/private_source_tasks.py show-identity",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "公开发布：上传当前平台产物到 GitHub",
      "type": "shell",
      "command": "python scripts/release/build_and_upload_current_platform_release.py --repo \"${input:githubPublicRepo}\" --release-root-dir \"Bin/github-staging-release\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "公开发布：触发 GitHub 汇总发布",
      "type": "shell",
      "command": "python scripts/release/dispatch_github_release_workflow.py --public-repo \"${input:githubPublicRepo}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "公开发布：手工直发最终 Release（兜底）",
      "type": "shell",
      "command": "python scripts/release/publish_github_release.py --repo \"${input:githubPublicRepo}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    }
  ]
}
