    {
      "label": "wateray: release patch + build windows client",
      "dependsOn": [
        "wateray: release patch",
        "wateray: build windows client"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "wateray: run desktop stack",
      "dependsOn": [
        "wateray: run vpn core",
        "wateray: run electron app"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "wateray: run windows stack",
      "dependsOn": [
        "wateray: run desktop stack"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
