{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "wateray: run electron app",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/ElectronApp"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "wateray: build electron app",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/ElectronApp"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "wateray: typecheck electron app",
      "type": "shell",
      "command": "npm run typecheck",
      "options": {
        "cwd": "${workspaceFolder}/ElectronApp"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "wateray: run vpn core",
      "type": "shell",
      "command": "go run -tags with_clash_api,with_gvisor ./cmd/waterayd",
      "options": {
        "cwd": "${workspaceFolder}/core"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "wateray: run desktop stack",
      "dependsOn": [
        "wateray: run vpn core",
        "wateray: run electron app"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "wateray: run windows stack",
      "dependsOn": [
        "wateray: run desktop stack"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
